# ─────────────────────────────────────────────────────
# Distinct Website — plantilla de variables de entorno
# Copia este archivo como .env.local y completa los valores.
# En Vercel, configura las mismas vars en el panel de Settings → Environment Variables.
# ─────────────────────────────────────────────────────

# Backend Django REST
# Local:   http://localhost:8000
# Vercel:  https://distinct-backend.<...>/  (URL de prod)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Moodle — acceso directo de cursos para clientes existentes
NEXT_PUBLIC_MOODLE_URL=https://moodle.traindistincthospitality.com

# Cuántos cursos se renderizan en el "Featured Courses" del home
NEXT_PUBLIC_HOME_COURSES_COUNT=3

# Path público donde están las imágenes de cursos
NEXT_PUBLIC_COURSE_IMAGE_BASE=/img/courses

# Correos de los 3 dueños (CSV) — destinatarios del flujo "Pay" / "I'm interested"
NEXT_PUBLIC_OWNER_EMAILS=Veronica@distincthospitalitysolutions.com,Luznedy@traindistinct.com,Hugo@traindistinct.com
